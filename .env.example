# Supabase Environment Variables
# Copie este arquivo para .env e preencha os valores

# Project URL (obtido em Settings > API > Project URL)
SUPABASE_URL=https://shyvzreadwnvgovgrqek.supabase.co

# Service Role Key (obtido em Settings > API > Project API Keys)
# NUNCA expor no front-end! Usar apenas em Edge Functions e back-end.
SUPABASE_SERVICE_ROLE_KEY=suasb_secret_aqui

# Anon Key (obtido em Settings > API > Project API Keys)
SUPABASE_ANON_KEY=suasb_publishable_aqui

# JWT Secret (gerado automaticamente pelo Supabase Auth)
JWT_SECRET=
